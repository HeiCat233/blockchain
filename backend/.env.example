# ============================================================
# 长安链 DID 系统 - 环境变量配置
# 说明：
#   - 复制此文件为 .env
#   - 根据需要修改配置
# ============================================================

# 运行模式
#   DEMO_MODE (默认): 文件存储，不需要长安链节点
#   CHAIN_MODE: 真实长安链，需要节点运行
RUN_MODE=DEMO_MODE

# 长安链节点配置
CHAIN_ID=chain1
ORG_ID=TestCMorg1
RPC_ADDR=localhost:12301
CONTRACT_NAME=did-contract

# 后端服务配置
PORT=3000
